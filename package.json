{
  "name": "poe-league-starter",
  "version": "0.1.0",
  "description": "Path of Exile League Start Leveling Guide Overlay",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "keywords": [
    "path of exile",
    "poe",
    "leveling",
    "overlay",
    "league start"
  ],
  "author": "Julie",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "dependencies": {
    "chokidar": "^3.5.3"
  },
  "build": {
    "appId": "com.poe.leaguestarter",
    "productName": "PoE League Starter",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "data/**/*",
      "config/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "category": "Game"
    }
  }
}
