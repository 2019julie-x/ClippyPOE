{
  "name": "clippy-poe",
  "version": "1.1.2",
  "description": "Path of Exile Campaign Guide Overlay",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "start:x11": "electron . --ozone-platform=x11",
    "start:wayland": "electron . --ozone-platform-hint=auto --enable-features=WaylandWindowDecorations",
    "dev": "electron . --dev",
    "dev:x11": "electron . --dev --ozone-platform=x11",
    "build": "electron-builder",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "projects": [
      {
        "displayName": "unit-node",
        "testEnvironment": "node",
        "testMatch": [
          "<rootDir>/tests/unit/logParser.test.js",
          "<rootDir>/tests/unit/overlayController.test.js",
          "<rootDir>/tests/unit/platformUtils.test.js",
          "<rootDir>/tests/unit/settingsManager.test.js",
          "<rootDir>/tests/unit/windowMagnetizer.test.js",
          "<rootDir>/tests/unit/timer.test.js",
          "<rootDir>/tests/integration/ipcChannels.test.js"
        ]
      },
      {
        "displayName": "unit-jsdom",
        "testEnvironment": "jsdom",
        "testMatch": [
          "<rootDir>/tests/unit/rendererApp.test.js"
        ]
      }
    ]
  },
  "keywords": [
    "path of exile",
    "poe",
    "leveling",
    "overlay",
    "league start"
  ],
  "author": "Julie",
  "license": "MIT",
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0"
  },
  "dependencies": {
    "chokidar": "^3.5.3"
  },
  "build": {
    "appId": "com.poe.clippypoe",
    "productName": "ClippyPOE",
    "publish": null,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "data/**/*",
      "config/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Game"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.games"
    }
  }
}
