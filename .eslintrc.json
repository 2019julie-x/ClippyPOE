{
  "env": {
    "node": true,
    "browser": true,
    "es2022": true,
    "jest": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "eqeqeq": ["error", "always"],
    "no-var": "error",
    "prefer-const": "warn",
    "curly": ["warn", "multi-line"],
    "no-throw-literal": "error"
  },
  "ignorePatterns": ["node_modules/", "dist/", "build/"]
}